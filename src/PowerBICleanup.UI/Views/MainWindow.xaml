<Window x:Class="PowerBICleanup.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PBI ModelLens"
        Height="720"
        Width="1100"
        MinHeight="600"
        MinWidth="900">

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open PBIP Project..."
                    Command="{Binding OpenProjectCommand}" />
                <Separator />
                <MenuItem Header="E_xit" />
            </MenuItem>

            <MenuItem Header="_Analyze">
                <MenuItem Header="_Run Analysis" />
            </MenuItem>

            <MenuItem Header="_View" />

            <MenuItem Header="_Tools" />

            <MenuItem Header="_Help">
                <MenuItem Header="_About PBI ModelLens" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Explorer"
                               FontWeight="Bold"
                               Padding="10"
                               Background="#F3F3F3" />

                    <TreeView Padding="8">
                        <TreeViewItem Header="Project" IsExpanded="True">
                            <TreeViewItem Header="Report" />
                            <TreeViewItem Header="Semantic Model" />
                            <TreeViewItem Header="Analysis" />
                        </TreeViewItem>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#EEEEEE" />

            <Border Grid.Column="2">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Details"
                               FontWeight="Bold"
                               Padding="10"
                               Background="#F3F3F3" />

                    <Grid>
                        <TextBlock Text="Select an item in the Explorer."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#777777"
                                   FontSize="16" />
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

    </DockPanel>
</Window>
